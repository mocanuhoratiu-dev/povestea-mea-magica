# Required for AI story generation. Use `vertex` to consume Google Cloud billing/credits.
NEXT_PUBLIC_SITE_MODE=demo
# Set this to the final https:// domain once it is connected. It powers canonical,
# Open Graph, robots.txt and sitemap.xml URLs.
NEXT_PUBLIC_SITE_URL=https://povestea-mea-magica-634103832719.europe-west3.run.app
AI_PROVIDER=vertex
VERTEX_AI_PROJECT_ID=project-e0c2efff-d456-48f9-9fe
VERTEX_AI_LOCATION=global
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_FALLBACK_MODELS=gemini-2.5-flash-lite
# Coperta este generată prin Vertex. Pollinations este doar fallback temporar,
# cu un prompt generic fără datele personale introduse pentru poveste.
VERTEX_AI_IMAGE_MODEL=gemini-2.5-flash-image
VERTEX_AI_IMAGE_FALLBACK_MODELS=
# Best-effort per-instance protection for the public beta. Add an edge rate
# limit before paid acquisition or traffic that can create multiple instances.
GENERATE_RATE_LIMIT_WINDOW_MS=3600000
GENERATE_RATE_LIMIT_MAX=5
# Aggregate telemetry is allow-listed, has no customer content and is stored in
# Cloud Run logs. This limit prevents the endpoint from being used as a log sink.
TELEMETRY_RATE_LIMIT_WINDOW_MS=86400000
TELEMETRY_RATE_LIMIT_MAX=120
# Optional local-only credential source. Cloud Run uses its runtime service account automatically.
# Base64-encoded service-account JSON should only be used when your Google Cloud policy allows it.
VERTEX_AI_SERVICE_ACCOUNT_JSON_BASE64=

# Optional fallback for Gemini Developer API / AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# Google Cloud Text-to-Speech voices for Romanian narration. Cloud Run uses its
# runtime service account, so no API key is stored here.
GOOGLE_TTS_STORY_VOICE=ro-RO-Chirp3-HD-Zephyr
GOOGLE_TTS_LUMI_VOICE=ro-RO-Chirp3-HD-Aoede

# Planned for the Stripe/order phase. Not required until checkout is enabled.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
N8N_WEBHOOK_URL=
